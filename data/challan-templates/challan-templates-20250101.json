        { "id": "cgstOther", "label": "CGST - Other", "type": "amount" },
        { "id": "sgstTax", "label": "SGST/UTGST - Tax", "type": "amount" },
        { "id": "sgstInterest", "label": "SGST/UTGST - Interest", "type": "amount" },
        { "id": "sgstPenalty", "label": "SGST/UTGST - Penalty", "type": "amount" },
        { "id": "sgstFee", "label": "SGST/UTGST - Fee", "type": "amount" },
        { "id": "sgstOther", "label": "SGST/UTGST - Other", "type": "amount" },
        { "id": "igstTax", "label": "IGST - Tax", "type": "amount" },
        { "id": "igstInterest", "label": "IGST - Interest", "type": "amount" },
        { "id": "igstPenalty", "label": "IGST - Penalty", "type": "amount" },
        { "id": "igstFee", "label": "IGST - Fee", "type": "amount" },
        { "id": "igstOther", "label": "IGST - Other", "type": "amount" },
        { "id": "cessTax", "label": "Cess - Tax", "type": "amount" },
        { "id": "cessInterest", "label": "Cess - Interest", "type": "amount" },
        { "id": "cessPenalty", "label": "Cess - Penalty", "type": "amount" },
        { "id": "cessFee", "label": "Cess - Fee", "type": "amount" },
        { "id": "cessOther", "label": "Cess - Other", "type": "amount" },
        { "id": "total", "label": "Total", "type": "amount_computed" },
        { "id": "totalInWords", "label": "Total in Words", "type": "text_computed" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
    {
      "templateId": "gst-drc-03",
      "name": "GST DRC-03 — Intimation of payment made voluntarily or made against the show cause notice or statement",
      "department": "CBIC (GST)",
      "description": "Challan for voluntary payment of GST liability identified by the taxpayer or in response to a departmental notice",
      "status": "active",
      "fields": [
        { "id": "gstin", "label": "GSTIN", "type": "text", "required": true },
        { "id": "name", "label": "Legal Name", "type": "text", "required": true },
        { "id": "paymentType", "label": "Cause of Payment", "type": "select", "required": true, "options": [
          { "code": "voluntary", "label": "Voluntary" },
          { "code": "scn", "label": "Against Show Cause Notice" },
          { "code": "statement", "label": "Against Statement" },
          { "code": "audit", "label": "Audit Findings" },
          { "code": "investigation", "label": "Investigation" },
          { "code": "other", "label": "Other" }
        ]},
        { "id": "periodFrom", "label": "Period From", "type": "date", "required": true },
        { "id": "periodTo", "label": "Period To", "type": "date", "required": true },
        { "id": "taxPaid", "label": "Tax Paid (CGST/SGST/IGST/Cess breakdown)", "type": "amount", "required": true },
        { "id": "interestPaid", "label": "Interest Paid", "type": "amount" },
        { "id": "penaltyPaid", "label": "Penalty Paid", "type": "amount" },
        { "id": "remarks", "label": "Remarks", "type": "textarea" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
    {
