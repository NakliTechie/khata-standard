{
  "datasetVersion": "2025-01-01",
  "description": "Tax payment challan templates — field definitions for generating printable challans. Covers the most common forms.",
  "publishedOn": "2025-01-01",
  "source": "CBIC, CBDT, EPFO, ESIC, and state tax department published forms",
  "notes": "Each template defines the field structure and metadata for a specific challan form. The application uses these to render printable PDFs matching the official layout. Real form PDFs, field coordinates, and reference numbers should be verified against the current official versions before production use. This starter set covers ITNS 280/281/282/283, GST PMT-06, GST DRC-03, PF ECR, ESIC, and Maharashtra PTRC/PTEC. Additional state-specific forms (Karnataka, Tamil Nadu, West Bengal, etc.) and other challans can be added as needed.",
  "templates": [
    {
      "templateId": "itns-280",
      "name": "ITNS 280 — Income Tax (Advance Tax, Self-Assessment Tax, Tax on Regular Assessment)",
      "department": "CBDT (Income Tax)",
      "description": "Challan for payment of income tax by individuals, HUFs, companies, and firms",
      "status": "active",
      "fields": [
        { "id": "pan", "label": "Permanent Account Number (PAN)", "type": "text", "required": true, "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]$" },
        { "id": "name", "label": "Full Name", "type": "text", "required": true },
        { "id": "address", "label": "Complete Address with City and State", "type": "textarea", "required": true },
        { "id": "pincode", "label": "Pin Code", "type": "text", "required": true, "pattern": "^[0-9]{6}$" },
        { "id": "assessmentYear", "label": "Assessment Year", "type": "select", "required": true, "options": "fy-list" },
        { "id": "taxType", "label": "Type of Payment", "type": "select", "required": true, "options": [
          { "code": "100", "label": "Advance Tax" },
          { "code": "102", "label": "Surtax" },
          { "code": "106", "label": "Tax on Distributed Profits of Domestic Companies" },
          { "code": "107", "label": "Tax on Distributed Income to Unit Holders" },
          { "code": "300", "label": "Self-Assessment Tax" },
          { "code": "400", "label": "Tax on Regular Assessment" }
        ]},
        { "id": "payeeCode", "label": "Payee Code (for companies / non-companies)", "type": "select", "required": true, "options": [
          { "code": "0020", "label": "Company" },
          { "code": "0021", "label": "Non-Company (Individual, HUF, Firm, etc.)" }
        ]},
        { "id": "income", "label": "Income Tax", "type": "amount", "required": true },
        { "id": "surcharge", "label": "Surcharge", "type": "amount" },
        { "id": "cess", "label": "Education Cess", "type": "amount" },
        { "id": "interest", "label": "Interest", "type": "amount" },
        { "id": "penalty", "label": "Penalty", "type": "amount" },
        { "id": "other", "label": "Others", "type": "amount" },
        { "id": "total", "label": "Total", "type": "amount_computed" },
        { "id": "totalInWords", "label": "Total in Words", "type": "text_computed" },
        { "id": "bank", "label": "Bank Name and Branch", "type": "text" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
    {
      "templateId": "itns-281",
      "name": "ITNS 281 — TDS / TCS",
      "department": "CBDT (Income Tax)",
      "description": "Challan for payment of TDS deducted and TCS collected",
      "status": "active",
      "fields": [
        { "id": "tan", "label": "Tax Deduction Account Number (TAN)", "type": "text", "required": true, "pattern": "^[A-Z]{4}[0-9]{5}[A-Z]$" },
        { "id": "name", "label": "Full Name of Deductor/Collector", "type": "text", "required": true },
        { "id": "address", "label": "Complete Address", "type": "textarea", "required": true },
        { "id": "pincode", "label": "Pin Code", "type": "text", "required": true, "pattern": "^[0-9]{6}$" },
        { "id": "natureOfPayment", "label": "Nature of Payment (Section)", "type": "select", "required": true, "options": "tds-sections" },
        { "id": "assessmentYear", "label": "Assessment Year", "type": "select", "required": true, "options": "fy-list" },
        { "id": "payeeType", "label": "Deductees Type", "type": "select", "required": true, "options": [
          { "code": "0020", "label": "Company" },
          { "code": "0021", "label": "Non-Company" }
        ]},
        { "id": "income", "label": "Income Tax", "type": "amount", "required": true },
        { "id": "surcharge", "label": "Surcharge", "type": "amount" },
        { "id": "cess", "label": "Education Cess", "type": "amount" },
        { "id": "interest", "label": "Interest", "type": "amount" },
        { "id": "penalty", "label": "Penalty (Fee u/s 234E)", "type": "amount" },
        { "id": "other", "label": "Others", "type": "amount" },
        { "id": "total", "label": "Total", "type": "amount_computed" },
        { "id": "totalInWords", "label": "Total in Words", "type": "text_computed" },
        { "id": "bank", "label": "Bank Name and Branch", "type": "text" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
    {
      "templateId": "itns-282",
      "name": "ITNS 282 — Securities Transaction Tax / Hotel Receipts Tax / Interest Tax / Expenditure Tax / Estate Duty / Wealth Tax / Gift Tax",
      "department": "CBDT (Income Tax)",
      "description": "Challan for payment of other direct taxes. Many of these taxes are legacy or abolished (wealth tax, gift tax). Retained for backward compatibility.",
      "status": "legacy",
      "note": "Primarily used today for Securities Transaction Tax (STT)",
      "fields": [
        { "id": "pan", "label": "PAN / TAN", "type": "text", "required": true },
        { "id": "name", "label": "Full Name", "type": "text", "required": true },
        { "id": "address", "label": "Address", "type": "textarea", "required": true },
        { "id": "assessmentYear", "label": "Assessment Year", "type": "select", "required": true, "options": "fy-list" },
        { "id": "natureOfPayment", "label": "Nature of Payment", "type": "text", "required": true },
        { "id": "amount", "label": "Amount", "type": "amount", "required": true },
        { "id": "total", "label": "Total", "type": "amount_computed" },
        { "id": "totalInWords", "label": "Total in Words", "type": "text_computed" },
        { "id": "bank", "label": "Bank Name and Branch", "type": "text" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
    {
      "templateId": "gst-pmt-06",
