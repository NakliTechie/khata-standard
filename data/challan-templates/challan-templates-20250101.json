        { "id": "adminChargesA", "label": "Admin Charges A/c No. 2", "type": "amount" },
        { "id": "adminChargesB", "label": "EDLI Admin Charges A/c No. 22", "type": "amount" },
        { "id": "total", "label": "Total Challan Amount", "type": "amount_computed" },
        { "id": "totalInWords", "label": "Total in Words", "type": "text_computed" },
        { "id": "challanDate", "label": "Date", "type": "date", "required": true }
      ]
    },
